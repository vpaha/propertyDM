@page "/requests"
@rendermode InteractiveAuto
@attribute [AllowAnonymous]

@inject ToastService toastService
@inject IDamageRepo damageRepo
@inject IAuthorizationService authz

<PageTitle>Track Property Repair Status | Property Claims</PageTitle>

<HeadContent>
    <meta name="description" content="Track your property damage claim online, review repair progress, and stay updated throughout the insurance claim process with Property Claims." />

    <link rel="canonical" href="https://www.propertyclaims.com/requests" />

    <meta property="og:title" content="Track Property Damage Claim Status | Repair Progress & Claim Updates | Property Claims" />
    <meta property="og:description" content="Track your property damage claim online, review repair progress, and stay updated throughout the insurance claim process with Property Claims." />
    <meta property="og:url" content="https://www.propertyclaims.com/requests" />
</HeadContent>

<section>
    <SfSpinner Size="48" Type="SpinnerType.Material" @bind-Visible="@isLoading"></SfSpinner>
    <SfAppBar role="region">
        <h1>List of repair requests</h1>
    </SfAppBar>
    <SfAppBar role="region">
        <h2>
            Review repair progress to proceed to next steps
        </h2>
        <SfButton type="button" CssClass="e-round e-outline" IsPrimary="true" OnClick="toggleBar" IconCss="e-icons e-drag-and-drop-indicator"></SfButton>
    </SfAppBar>
    <div id="main-container">
        <div id="data-container" class="zoom-in">
            @if (damageList?.Any() == true)
            {
                @foreach (var item in damageList)
                {
                    @if (isVendor)
                    {
                        <DamageInfo DamageContext="@item" OnToggleBladeEvent="ToggleBlade" IsBladeOpen="isSideBarOpen" />
                    }
                    else
                    {
                        <Tracking DamageContext="@item" OnToggleBladeEvent="ToggleBlade" IsBladeOpen="isSideBarOpen" />
                    }
                }
            }
        </div>
    </div>
    <SfSidebar ID="side-bar-blade" @bind-IsOpen="isSideBarOpen" Type="(IsDesktopView ? SidebarType.Push : SidebarType.Over)" Target="#main-container" Position="SidebarPosition.Right">
        <ChildContent>
            @if (EditContext is not null)
            {
                <SfDataForm EditContext="@EditContext" LabelPosition="FormLabelPosition.Top">
                    <FormValidator>
                        <DataAnnotationsValidator></DataAnnotationsValidator>
                    </FormValidator>
                    <FormTemplate>
                        <SfCard role="region">
                            @{
                                foreach (var item in damageContext.Sections)
                                    if (!string.IsNullOrWhiteSpace(item.Entry))
                                    {
                                        <CardContent EnableSeparator="true">
                                            <strong>@item.DamageSectionType?.Name</strong>
                                            <div>@item.Entry</div>
                                        </CardContent>
                                    }
                            }
                        </SfCard>
                        @if (isVendor)
                        {
                            <div id="form-buttons">
                                <SfButton type="button" Content="Run Review"
                                          IconCss="e-icons e-smart-paste" IconPosition="IconPosition.Right" IsPrimary="true"
                                          CssClass="@((damageContext.IsProcessed == true ? "e-outline" : ""))"
                                          OnClick="OnSubmit">
                                </SfButton>
                                <SfButton type="button" Content="Upload Pictures"
                                          IconCss="e-icons e-smart-paste" IconPosition="IconPosition.Left" IsPrimary="true"
                                          CssClass="@((damageContext.IsProcessed == true ? "e-outline" : ""))"
                                          OnClick="OnUpload">
                                </SfButton>
                            </div>
                            <DamageForm DamageContext="@damageContext"></DamageForm>
                        }
                    </FormTemplate>
                    <FormButtons></FormButtons>
                </SfDataForm>
            }
        </ChildContent>
    </SfSidebar>
</section>
<style>
    #side-bar-blade {
        border: solid 1px grey;
        border-radius: 8px;
        max-width: 324px;
        padding: 10px 15px 10px 15px;
    }

        #side-bar-blade #form-buttons {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            padding-bottom: 5px;
            padding-top: 5px;
            margin-bottom: 5px;
            margin-top: 5px;
        }

    #main-container {
        padding-right: 2px;
        padding-left: 2px;
    }

        #main-container #data-container {
            min-height: 70vh;
        }

            #main-container #data-container .e-card {
                margin-bottom: 6px;
            }

</style>

@code {
    [CascadingParameter] private Task<AuthenticationState> authStateTask { get; set; } = default!;
    [CascadingParameter(Name = CascadingParams.MediaQuery)] private bool IsDesktopView { get; set; }

    public EditContext EditContext { get; set; } = default!;

    private bool isSideBarOpen { get; set; } = false;
    private void toggleBar() => isSideBarOpen = !isSideBarOpen;

    IReadOnlyList<DamageEntry> damageList { get; set; } = default!;
    DamageEntry damageContext { get; set; } = default!;

    private bool isLoading { get; set; } = true;

    private bool isVendor { get; set; }

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        try
        {
            var authState = await authStateTask;
            var result = await authz.AuthorizeAsync(authState.User, "Vendor");

            int? vendorId = null;
            if (result.Succeeded)
            {
                isVendor = true;

                var value = authState.User.FindFirst("vendor_id")?.Value;
                if (int.TryParse(value, out var parsedId))
                {
                    vendorId = parsedId;
                }
            }
            damageList = await damageRepo.ListDamageEntriesAsync(vendorId, CancellationToken.None);
        } catch (Exception ex)
        {
            toastService.ShowError(ex.Message);
        } finally
        {
            isLoading = false;
        }
    }

    private async Task ToggleBlade(DamageEntry damage)
    {
        damageContext = damage;
        EditContext = new EditContext(damageContext);

        toggleBar();
    }

    private async Task OnSubmit()
    {
        if (!EditContext.Validate()) return;

        // damageContext.IsProcessed = true;
        // if (isVendor)
        //     await vendorRepo.UpdateEntryAsync(damageContext, CancellationToken.None);
        // else
        //     await damageRepo.UpdateEntryAsync(damageContext, CancellationToken.None);
    }

    private async Task OnUpload()
    {
        if (!EditContext.Validate()) return;
    }
}