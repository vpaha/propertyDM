@page "/settings"
@rendermode InteractiveAuto
@attribute [AllowAnonymous]

@using Microsoft.JSInterop
@using System.Security.Claims

@inject IJSRuntime JSRuntime
@inject NavigationManager nav
@inject HttpClient _httpClient
@inject IUserService userService
@inject ToastService toastService

<PageTitle>Settings</PageTitle>

<section>
    <SfCard role="region">
        <CardHeader>Settings</CardHeader>
        <CardContent EnableSeparator="true">
            <div class="settings-row">
                <label for="isdark-check">Switch to dark mode:</label>
                <SfSwitch id="isdark-check" TChecked="bool" Checked="@theme.IsDarkMode" ValueChange="OnDarkModeChange" />
            </div>
        </CardContent>
        <CardContent EnableSeparator="true">
            <div>
                <a href="authentication/clear" class="e-btn e-primary e-outline" title="browser Cache">Clear browser Cache</a>
            </div>
        </CardContent>
        <CardContent EnableSeparator="true">
            <div style="width: fit-content;">
                <label for="culture-select">Region:</label>
                <SfDropDownList id="culture-select" TValue="string" TItem="CultureOption" DataSource="@cultures.Options" Value="@selected" aria-label="Culture">
                    <DropDownListFieldSettings Text="Country" Value="Culture" />
                    <DropDownListEvents TValue="string" TItem="CultureOption" ValueChange="OnCultureChanged" />
                </SfDropDownList>
            </div>
            <div style="width: fit-content;">
                <SfDatePicker TValue="DateOnly?" Format="@CultureInfo.CurrentCulture.DateTimeFormat.ShortDatePattern" aria-label="Date value"
                              Placeholder="Date only" FloatLabelType="FloatLabelType.Always" EnableMask="true" ShowClearButton="true">
                    <DatePickerMaskPlaceholder Day="dd" Month="mm" Year="yyyy"></DatePickerMaskPlaceholder>
                </SfDatePicker>
                <SfDateTimePicker TValue="DateTime?" Format="g"
                                  Placeholder="Date and Time" aria-label="Date and Time value"
                                  Step="60" CssClass="e-small" FloatLabelType="FloatLabelType.Always"
                                  EnableMask="true" ShowClearButton="true">
                    <DatePickerMaskPlaceholder Day="dd" Month="mm" Year="yyyy" Hour="hh" Minute="mm"></DatePickerMaskPlaceholder>
                </SfDateTimePicker>
                <SfDateRangePicker TValue="DateOnly?" Format="@CultureInfo.CurrentCulture.DateTimeFormat.ShortDatePattern"
                                   Placeholder="Date Range" aria-label="Date Range value"
                                   OpenOnFocus="true" ShowClearButton="true" Separator="to"
                                   CssClass="e-small" FloatLabelType="FloatLabelType.Always">
                    <DateRangePickerPresets>
                        <DateRangePickerPreset Label="Last 2 Days" Start="DateTime.Now.AddDays(-2).Date" End="DateTime.Now.Date"></DateRangePickerPreset>
                        <DateRangePickerPreset Label="Last Week" Start="DateTime.Now.AddDays(-7).Date" End="DateTime.Now.Date"></DateRangePickerPreset>
                        <DateRangePickerPreset Label="Last Month" Start="DateTime.Now.AddMonths(-1).Date" End="DateTime.Now.Date"></DateRangePickerPreset>
                        <DateRangePickerPreset Label="Year to Date" Start="new DateTime(DateTime.Now.Year, 1, 1)" End="DateTime.Now.Date"></DateRangePickerPreset>
                        <DateRangePickerPreset Label="Past Year" Start="DateTime.Now.AddYears(-1).Date" End="DateTime.Now.Date"></DateRangePickerPreset>
                    </DateRangePickerPresets>
                </SfDateRangePicker>
            </div>
            <div style="width: fit-content;">
                <SfNumericTextBox Placeholder="Currency" FloatLabelType="FloatLabelType.Always" TValue="Decimal?" Format="C" aria-label="Currency value" Value="100"></SfNumericTextBox>
            </div>
        </CardContent>
        <AuthorizeView Policy="Admin">
            <Authorized>
                <CardContent EnableSeparator="true">
                    <UserList RefreshRequested="RefreshPageAsync"></UserList>
                </CardContent>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView>
            <Authorized>
                <UserContextInfo RefreshVersion="refreshVersion"></UserContextInfo>
            </Authorized>
        </AuthorizeView>
    </SfCard>
</section>
<style>
    .settings-row {
        display: flex;
        align-items: center;
        gap: 30px;
    }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState> authStateTask { get; set; } = default!;

    private sealed record ThemeSettings(string ThemeName, bool IsDarkMode, string Culture);

    private ThemeSettings CreateTheme(string culture) => new("Default", false, culture);

    private readonly CultureData cultures = new();
    private string selected = string.Empty;
    private ThemeSettings theme { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        selected = GetInitialCulture();
        theme = CreateTheme(selected);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var stored = await JSRuntime.InvokeAsync<ThemeSettings?>("getTheme");
        if (stored is null) return;

        ApplyTheme(stored);
        StateHasChanged();
    }

    private async Task OnDarkModeChange(Syncfusion.Blazor.Buttons.ChangeEventArgs<bool> args)
    {
        ApplyTheme(theme with
        {
            IsDarkMode = args.Checked
        });
        await PersistThemeAsync();
    }

    private async Task OnCultureChanged(ChangeEventArgs<string, CultureOption> args)
    {
        var culture = args?.Value;
        if (string.IsNullOrWhiteSpace(culture) || culture.Equals(selected, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }
        ApplyTheme(theme with { Culture = culture });

        await JSRuntime.InvokeVoidAsync("setCulture", selected);
        await PersistThemeAsync();

        nav.NavigateTo(nav.Uri, forceLoad: true);
    }

    private void ApplyTheme(ThemeSettings value)
    {
        theme = value;
        selected = value.Culture;
    }

    private string GetInitialCulture()
    {
        var currentCulture = CultureInfo.CurrentCulture.Name;

        return cultures.Options.Any(c =>
            c.Culture.Equals(currentCulture, StringComparison.OrdinalIgnoreCase))
            ? currentCulture
            : cultures.DefaultCulture.Name;
    }

    private async Task PersistThemeAsync()
    {
        await JSRuntime.InvokeVoidAsync("setTheme", theme);
        await _httpClient.PostAsJsonAsync(nav.ToAbsoluteUri("config/theme"), theme);
    }

    private int refreshVersion;

    private async Task RefreshPageAsync(AppUser user)
    {
        var authState = await authStateTask;
        await userService.ProvisionAsync(authState.User);

        await userService.UpdateUserAsync(user);

        refreshVersion++;
        StateHasChanged();

        toastService.ShowSuccess("User updated successfully.");
    }
}