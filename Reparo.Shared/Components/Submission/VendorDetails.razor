@rendermode InteractiveAuto

@inject IVendorRepo vendorRepo
@inject ToastService toastService

<section id="vendor-page" class="fade-in">
    @if (Vendor is not null)
    {
        <SfAppBar role="region">
            <h2>Vendor information and contact details</h2>
        </SfAppBar>
        <SfCard>
            <CardHeader>
                <h3>Business Information</h3>
            </CardHeader>
            <CardContent>
                <div>
                    @Vendor.Name
                </div>
                @if (!string.IsNullOrWhiteSpace(Vendor.LegalName))
                {
                    <div>
                        <strong>Legal Name</strong><br />
                        @Vendor.LegalName
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Vendor.Description))
                {
                    <div>
                        <strong>Description</strong><br />
                        @Vendor.Description
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Vendor.LicenseNumber))
                {
                    <div>
                        <strong>License Number</strong><br />
                        @Vendor.LicenseNumber
                    </div>
                }
            </CardContent>
        </SfCard>
        <SfCard>
            <CardHeader>
                <h3>Contact</h3>
            </CardHeader>
            <CardContent>
                @if (!string.IsNullOrWhiteSpace(Vendor.Email))
                {
                    <div>
                        <strong>Email</strong><br />
                        <a href="@($"mailto:{Vendor.Email}")">@Vendor.Email</a>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Vendor.Phone))
                {
                    <div>
                        <strong>Phone</strong><br />
                        <a href="@($"tel:{Vendor.Phone}")">@Vendor.Phone</a>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Vendor.WebsiteUrl))
                {
                    <div>
                        <strong>Website</strong><br />
                        <a href="@Vendor.WebsiteUrl"
                               target="_blank"
                               rel="noopener noreferrer">
                            @Vendor.WebsiteUrl
                        </a>
                    </div>
                }
            </CardContent>
        </SfCard>
        @if (!string.IsNullOrWhiteSpace(FormattedAddress))
        {
            <SfCard>
                <CardHeader>
                    <h3>Address</h3>
                </CardHeader>
                <CardContent>
                    <div>
                        <strong>Location</strong><br />
                        @FormattedAddress
                    </div>
                </CardContent>
            </SfCard>
        }
        <SfCard>
            <CardHeader>
                <h3>Vendor Status</h3>
            </CardHeader>
            <CardContent>
                <div>
                    <strong>Active</strong> @(Vendor.IsActive ? "Yes" : "No")
                </div>
                <div>
                    <strong>Verified</strong> @(Vendor.IsVerified ? "Yes" : "No")
                </div>
                <div>
                    <strong>Preferred</strong> @(Vendor.IsPreferred ? "Yes" : "No")
                </div>
                @if (Vendor.Rating.HasValue)
                {
                    <div>
                        <strong>Rating</strong> @Vendor.Rating.Value.ToString("0.0")
                    </div>
                }
                @if (Vendor.ReviewCount.HasValue)
                {
                    <div>
                        <strong>Review Count</strong> @Vendor.ReviewCount
                    </div>
                }
            </CardContent>
        </SfCard>
    }
</section>
<style>
    #vendor-page {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        min-height: 80px;
        align-content: center;
    }

        #vendor-page .e-card {
            flex: 1 1 260px;
        }
</style>

@code {
    [Parameter]
    public VendorModel Vendor { get; set; } = default!;

    private string FormattedAddress =>
        string.Join(", ",
            new[]
            {
                Vendor.AddressLine1,
                Vendor.AddressLine2,
                Vendor.City,
                Vendor.State,
                Vendor.PostalCode,
                Vendor.Country
            }.Where(x => !string.IsNullOrWhiteSpace(x)));
}