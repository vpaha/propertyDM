@using Syncfusion.Blazor.Navigations

<SfCarousel ID="control-container" AnimationEffect="CarouselAnimationEffect.Fade">
    @foreach (var image in Images)
    {
        <CarouselItem>
            <figure>
                <img src="@image.Url" alt="@image.FileName" />
                <figcaption>@image.FileName</figcaption>
            </figure>
        </CarouselItem>
    }
</SfCarousel>

<style>
    #control-container {
        margin: 0 auto;
    }
</style>

@code {
    [Parameter] public long DamageId { get; set; }

    private List<ImageItem> Images { get; set; } = [];

    protected override void OnParametersSet()
    {
        var uploadDirectory = Path.Combine("wwwroot", "Images", DamageId.ToString());
        if (!Directory.Exists(uploadDirectory))
        {
            Images = [];
            return;
        }

        Images = Directory.EnumerateFiles(uploadDirectory).Where(IsImageFile)
            .Select(file => new ImageItem
            {
                FileName = Path.GetFileName(file),
                Url = $"/Images/{DamageId}/{Path.GetFileName(file)}"
            })
            .ToList();
    }

    private static bool IsImageFile(string filePath)
    {
        var extension = Path.GetExtension(filePath).ToLowerInvariant();
        return extension is ".jpg" or ".jpeg" or ".png" or ".gif" or ".webp";
    }

    private sealed class ImageItem
    {
        public string FileName { get; set; } = string.Empty;
        public string Url { get; set; } = string.Empty;
    }
}