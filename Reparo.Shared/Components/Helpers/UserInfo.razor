@using Microsoft.AspNetCore.Components.Authorization;

<AuthorizeView>
    <Authorized Context="auth">
        <div>
            <strong>User:</strong> @auth.User.Identity?.Name
        </div>
        <div>
            <strong>Auth Type:</strong> @auth.User.Identity?.AuthenticationType
        </div>
        <h3>All Claims:</h3>
        @if (auth.User.Claims?.Any() == true)
        {
            <ul>
                @foreach (var claim in auth.User.Claims.OrderBy(c => c.Type))
                {
                    <li>
                        <strong>@claim.Type</strong>: @claim.Value
                    </li>
                }
            </ul>
        }
    </Authorized>
</AuthorizeView>