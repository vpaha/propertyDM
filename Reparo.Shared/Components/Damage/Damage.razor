@rendermode InteractiveAuto
<SfCard role="link">
    <CardContent>
        <div id="damage-brief">
            <div id="damage-summary">
                <div>
                    xxxxxxxxxxxxxxxxxxxxx
                    Damage reported at @DamageContext.Street @DamageContext.City @DamageContext.State @DamageContext.Zip on
                    @($"{DamageContext.DateOfLoss:f}")
                </div>
                @{
                    foreach (var item in DamageContext.Sections)
                        if (!string.IsNullOrWhiteSpace(item.Entry))
                        {
                            <div>
                                <strong>Requested @item.DamageSectionType?.Name</strong>
                                <div>@item.Entry</div>
                            </div>
                        }
                }
            </div>
            <div>
                <SfButton type="button" CssClass="e-outline e-primary" OnClick="ToggleBlade" Content="@(IsBladeOpen ? "Hide" : "Edit damage")">
                </SfButton>
            </div>
        </div>
    </CardContent>
</SfCard>
<style>
    #damage-brief {
        display: flex;
        justify-content: space-between;
    }

    #damage-summary {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }
</style>
@code {
    [Parameter] public DamageEntry DamageContext { get; set; } = default!;
    [Parameter] public bool IsBladeOpen { get; set; } = default!;
    [Parameter] public EventCallback<DamageEntry> OnToggleBladeEvent { get; set; }

    private async Task ToggleBlade()
    {
        await OnToggleBladeEvent.InvokeAsync(DamageContext);
    }
}