@using Microsoft.AspNetCore.Components.Authorization
@inject IUserRepo userRepo

<h3>User list</h3>
<SfGrid TValue="AppUser"
        DataSource="@appUsers"
        Toolbar="@(new List<string> { "Edit", "Update", "Cancel", "Search" })"
        AllowPaging="true"
        AllowReordering="true"
        AllowSorting="true"
        AllowFiltering="true"
        ShowColumnMenu="true">
    <GridEditSettings AllowEditing="true" Mode="EditMode.Normal"></GridEditSettings>
    <GridPageSettings PageSize="GridConstants.RowCount"></GridPageSettings>
    <GridSearchSettings Fields="@(new[] { nameof(AppUser.UserName), nameof(AppUser.Email), nameof(AppUser.ProviderDisplayName) })"
                        Operator="Syncfusion.Blazor.Operator.StartsWith"
                        IgnoreCase="true"
                        IgnoreAccent="true">
    </GridSearchSettings>
    <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.CheckBox" Mode="FilterBarMode.Immediate"></GridFilterSettings>
    <GridColumns>
        <GridColumn Field="@nameof(AppUser.UserName)" HeaderText="User name" IsPrimaryKey="true" AllowEditing="false"></GridColumn>
        <GridColumn Field="@nameof(AppUser.ProviderDisplayName)" HeaderText="Provider" AllowEditing="false"></GridColumn>
        <GridColumn Field="@nameof(AppUser.Email)" HeaderText="Email"></GridColumn>
        <GridColumn Field="@nameof(AppUser.PhoneNumber)" HeaderText="Phone number"></GridColumn>
        <GridColumn Field="@nameof(AppUser.RoleNames)" HeaderText="Roles">
            <Template>
                @{
                    var user = (AppUser)context;
                    <span>@string.Join(", ", user.RoleNames)</span>
                }
            </Template>
            <EditTemplate>
                @{
                    var user = (AppUser)context;
                    <SfMultiSelect TItem="AppRole" TValue="AppRole[]" DataSource="@availableRoles" @bind-Value="user.Roles"
                                   Placeholder="Select roles" Mode="VisualMode.Box" ShowDropDownIcon="true"
                                   AllowFiltering="true" ShowClearButton="true">
                        <MultiSelectFieldSettings Text="Name" Value="Id" />
                    </SfMultiSelect>
                }
            </EditTemplate>
        </GridColumn>
    </GridColumns>
    <GridEvents TValue="AppUser" OnActionBegin="OnActionBegin"></GridEvents>
</SfGrid>
@code {
    [Parameter]
    public EventCallback RefreshRequested { get; set; }

    private IReadOnlyList<AppUser> appUsers { get; set; } = [];
    private IReadOnlyList<AppRole> availableRoles { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        appUsers = await userRepo.GetUsersAsync();
        availableRoles = await userRepo.GetRolesAsync();
    }

    private async Task OnActionBegin(ActionEventArgs<AppUser> args)
    {
        if (args.RequestType == Syncfusion.Blazor.Grids.Action.Save && args.Data is not null)
        {
            await userRepo.UpdateRolesAsync(args.Data);
            await RefreshRequested.InvokeAsync();
        }
    }
}