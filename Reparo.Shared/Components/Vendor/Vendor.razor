@inject IVendorRepo vendorRepo
@inject ToastService toastService

<section id="vendor-page" class="zoom-in">
    <SfSpinner Size="48" Type="SpinnerType.Material" @bind-Visible="@isLoading"></SfSpinner>
    <VendorDetails Vendor="model"></VendorDetails>
</section>
<style>
    #vendor-page {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        min-height: 80px;
        align-content: center;
    }

        #vendor-page .e-card {
            flex: 1 1 260px;
        }
</style>

@code {
    [Parameter]
    public string? PlaceId { get; set; }
    [Inject]
    public DamageState DamageState { get; set; } = default!;

    private VendorModel? model { get; set; }
    private bool isLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(PlaceId)) return;

        isLoading = true;
        try
        {
            model = await vendorRepo.GetVendorByPlaceAsync(PlaceId);

            DamageState.Context.Vendor = model;
            DamageState.Context.VendorId = DamageState.Context.Vendor?.Id;
        } catch (Exception)
        {
        } finally
        {
            isLoading = false;
        }
    }
}